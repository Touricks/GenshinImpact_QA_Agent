# ===========================================
# AmberProject - 环境变量配置
# ===========================================
# 游戏剧情问答 Agent (Nod-Krai 区域)
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制

# ==================== LLM 提供商 ====================
# Google Gemini — 主力 LLM
# 获取方式：https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ==================== 模型配置（三类模型） ====================
# REASONING_MODEL: 主 Agent 推理、工具编排（需要强推理能力）
REASONING_MODEL=gemini-3-pro-preview

# GRADER_MODEL: 答案质量评分、Query 改写（快速模型）
GRADER_MODEL=gemini-2.5-flash

# DATA_MODEL: 结构化输出（KG/Event 提取）
DATA_MODEL=gemini-2.5-flash

# ==================== Fallback 提供商（可选） ====================
# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI GPT-4
# OPENAI_API_KEY=sk-xxxxx

# 阿里云 Qwen
# DASHSCOPE_API_KEY=sk-xxxxx

# ==================== Embedding 配置 ====================
# 使用本地 BAAI/bge-m3 模型，无需远程 API
# 如使用 OpenAI embedding:
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 本地嵌入模型路径（可选，默认自动下载）
# LOCAL_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5

# ==================== 向量数据库 - Qdrant ====================
# Docker 本地部署：docker compose up -d
QDRANT_HOST=localhost
QDRANT_PORT=6333
# 如使用 Qdrant Cloud:
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=xxxxx

# ==================== 图数据库 - Neo4j ====================
# Docker 本地部署：docker compose up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=genshin_story_qa

# ==================== Reranker 配置 ====================
# 本地 Jina Reranker（跨语言重排序）
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANKER_TOP_K=3

# ==================== 应用配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=./Data

# 索引存储目录
INDEX_DIR=./index_storage

# ==================== 消融测试 ====================
# full: KG + Vector 完整模式
# vector_only: 仅向量检索（禁用 KG 工具）
ABLATION_MODE=full

# ==================== LangSmith 追踪（可选） ====================
# LangGraph 工作流可视化追踪与调试
# 获取方式：https://smith.langchain.com/ → Settings → API Keys
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=amber-genshin-qa
